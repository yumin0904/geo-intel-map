# ── Geo-Intel-Map 환경 변수 템플릿 ──────────────────────────────
# 이 파일을 .env로 복사 후 실제 키값 입력
#   cp .env.example .env
# .env는 .gitignore에 포함 — 절대 커밋 금지

# ── Phase 1: ACLED 분쟁 이벤트 ──────────────────────────────────
# 계정: https://acleddata.com/register/  (학술용 무료)
# 인증: OAuth 2.0 Resource Owner Password Credentials
ACLED_EMAIL=your_email@example.com
ACLED_PASSWORD=your_acled_password_here
# OAuth 도입 이후 URL 변경 시 여기서만 수정 (기본값: api.acleddata.com)
ACLED_API_URL=https://api.acleddata.com/acled/read

# ── Phase 3: Gemini 번역 (ACLED ⭐ 이벤트 on-demand 번역) ────────
# 발급: https://aistudio.google.com/app/apikey  (무료 티어 사용 가능)
# 미설정 시 번역 버튼이 안내 메시지를 표시하며, 나머지 기능은 정상 동작
GEMINI_API_KEY=your_gemini_api_key_here

# ── Phase 2 이후 (아직 미사용) ───────────────────────────────────
# NASA FIRMS (위성 화재/열점)
# NASA_FIRMS_API_KEY=your_firms_key_here

# OpenSky Network (군용기 ADS-B)
# OPENSKY_USERNAME=your_username
# OPENSKY_PASSWORD=your_password
